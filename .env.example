# MerchMind Environment Variables
# Copy this to .env and fill in your values

# ── API Gateway ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000
JWT_SECRET=merchmind_jwt_secret_change_in_production
JWT_EXPIRES=24h
FRONTEND_URL=http://localhost:3000
AI_ENGINE_URL=http://localhost:8000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://merchmind:password@localhost:5432/merchmind
MONGODB_URL=mongodb://localhost:27017/merchmind
REDIS_URL=redis://localhost:6379

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── AI/ML (Optional — LangChain can use local models) ────────
OPENAI_API_KEY=your_key_here_optional
MODEL_CACHE_DIR=./models

# ── External Data APIs (Optional) ─────────────────────────────
WEATHER_API_KEY=your_openweather_key
EVENTS_API_KEY=your_predicthq_key
